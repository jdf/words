{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "wasm-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/ports",
        "VCPKG_TARGET_TRIPLET": "wasm32-emscripten",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "VCPKG_MANIFEST_FEATURES": "bench"
      },
      "environment": {
        "VCPKG_ROOT": "$penv{VCPKG_ROOT}",
        "EMSDK": "$penv{EMSDK}"
      }
    },
    {
      "name": "wasm-debug",
      "displayName": "WASM Debug",
      "inherits": "wasm-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "wasm-release",
      "displayName": "WASM Release",
      "inherits": "wasm-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "host-test",
      "displayName": "Host geometry tests",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "VCPKG_MANIFEST_FEATURES": "tests"
      },
      "environment": {
        "VCPKG_ROOT": "$penv{VCPKG_ROOT}"
      }
    },
    {
      "name": "host-coverage",
      "displayName": "Host tests with coverage instrumentation",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "VCPKG_MANIFEST_FEATURES": "tests",
        "WORDS_COVERAGE": "ON"
      },
      "environment": {
        "VCPKG_ROOT": "$penv{VCPKG_ROOT}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "wasm-debug",
      "configurePreset": "wasm-debug"
    },
    {
      "name": "wasm-release",
      "configurePreset": "wasm-release"
    },
    {
      "name": "host-test",
      "configurePreset": "host-test"
    },
    {
      "name": "host-coverage",
      "configurePreset": "host-coverage"
    }
  ],
  "testPresets": [
    {
      "name": "host-test",
      "configurePreset": "host-test",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "host-coverage",
      "configurePreset": "host-coverage",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
