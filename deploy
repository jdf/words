#!/usr/bin/env bash
# Build the release dist, stage it into the site repo
# (~/mrfeinberg.com/words/), commit that repo, and rsync the words/
# subtree to the web host.
#
#   ./deploy           build, stage, commit the site repo, upload
#   ./deploy -n        build, stage (no commit), rsync dry run
#
# The site repo is the deployed artifact: all of mrfeinberg.com is
# versioned there, words/ included, so every deploy is a commit with
# history and rollback. The remote sync uses the mrfeinberg-claude ssh
# alias (a dedicated key; see ~/.ssh/config) and --delete scoped to
# words/ only — that subtree is fully generated from this repo, so
# deletions in it are always safe. (The site-wide deploy never uses
# --delete; see commands/deploy-mrfeinberg-dot-com.md.)
set -euo pipefail
cd "$(dirname "$0")"

SITE="${WORDS_SITE_DIR:-$HOME/mrfeinberg.com}"
REMOTE="${WORDS_REMOTE:-mrfeinberg-claude:mrfeinberg.com/words/}"

DRY=""
if [ "${1:-}" = "-n" ]; then
  DRY="-n"
  shift
fi

# Make sure what we stage is the current release build.
export VCPKG_ROOT="${VCPKG_ROOT:-$HOME/vcpkg}"
export EMSDK="${EMSDK:-$HOME/emsdk}"
export PATH="$EMSDK/upstream/emscripten:$PATH"
if [ ! -f build/wasm-release/build.ninja ]; then
  cmake --preset wasm-release >/dev/null
fi
cmake --build --preset wasm-release

DIST="$PWD/build/wasm-release/dist"
for f in index.html app.js worker.js words.js words.wasm words.data \
         credits.html .htaccess; do
  if [ ! -f "$DIST/$f" ]; then
    echo "deploy: $DIST/$f missing after build" >&2
    exit 1
  fi
done
if [ ! -d "$SITE/.jj" ]; then
  echo "deploy: $SITE is not the site repo" >&2
  exit 1
fi

# Stage: the site repo's words/ mirrors dist exactly. (.DS_Store is
# Finder droppings — excluded here and below, and excluded from
# deletion by the same flag, so it never dirties commits or uploads.)
rsync -a --delete --exclude .DS_Store "$DIST/" "$SITE/words/"

BUILD_ID=$(sed -n "s/.*id: '\([^']*\)'.*/\1/p" "$DIST/build-info.js")
if [ -z "$DRY" ]; then
  # Commit the site repo, scoped to words/ (a re-deploy of an unchanged
  # build stages nothing and commits nothing). Run from inside the
  # repo: jj filesets resolve against the cwd.
  if [ -n "$(cd "$SITE" && jj diff --summary words)" ]; then
    (cd "$SITE" && jj commit words -m "words build $BUILD_ID")
  else
    echo "deploy: site repo already at words build $BUILD_ID"
  fi
fi

exec rsync -rlptDv --delete --exclude .DS_Store $DRY "$@" \
  "$SITE/words/" "$REMOTE"
