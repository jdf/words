Checks: '-*,misc-include-cleaner'
WarningsAsErrors: 'misc-include-cleaner'
HeaderFilterRegex: 'src/.*'
CheckOptions:
  # Emscripten/GL headers confuse include-cleaner (symbols resolve through
  # internal paths); don't suggest inserting or removing them.
  # clipper2/ for the same reason clangd's .clangd exempts it: the public
  # umbrella header lacks IWYU export pragmas, so symbols are attributed to
  # internal headers (clipper.core.h etc.).
  misc-include-cleaner.IgnoreHeaders: 'emscripten/.*;GLES3/.*;GL/.*;clipper2/.*'
